{
  "name": "@rokmohar/medusa-plugin-meilisearch",
  "version": "1.4.1",
  "description": "Meilisearch plugin for Medusa 2",
  "author": "Rok Mohar",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rokmohar/medusa-plugin-meilisearch.git"
  },
  "keywords": [
    "medusa",
    "medusa-v2",
    "medusa-plugin",
    "medusa-plugin-integration",
    "medusa-plugin-meilisearch",
    "medusa-plugin-search"
  ],
  "files": [
    ".medusa/server"
  ],
  "main": ".medusa/server/src/index.js",
  "exports": {
    "./package.json": "./package.json",
    "./admin": {
      "import": "./.medusa/server/src/admin/index.mjs",
      "require": "./.medusa/server/src/admin/index.js",
      "default": "./.medusa/server/src/admin/index.js"
    },
    "./workflows": "./.medusa/server/src/workflows/index.js",
    "./.medusa/server/src/modules/*": "./.medusa/server/src/modules/*/index.js",
    ".": "./.medusa/server/src/modules/meilisearch/index.js"
  },
  "scripts": {
    "build": "medusa plugin:build",
    "dev": "medusa plugin:develop",
    "prepublishOnly": "medusa plugin:build",
    "typecheck": "tsc --noEmit --pretty --project tsconfig.json",
    "lint": "eslint \"src/**/*.ts\" --cache --cache-strategy content",
    "lint:fix": "eslint \"src/**/*.ts\" --fix --cache --cache-strategy content",
    "format": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\" --cache --cache-strategy content --log-level warn",
    "format:fix": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\" --cache --cache-strategy content --log-level warn"
  },
  "dependencies": {
    "meilisearch": "^0.56.0"
  },
  "devDependencies": {
    "@medusajs/admin-sdk": "^2.15.2",
    "@medusajs/cli": "^2.15.2",
    "@medusajs/framework": "^2.15.2",
    "@medusajs/medusa": "^2.15.2",
    "@medusajs/ui": "^4.1.12",
    "@swc/core": "^1.15.33",
    "@tanstack/react-query": "5.64.2",
    "@types/node": "^22",
    "@types/react": "^18",
    "awilix": "^8.0.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^16",
    "prettier": "^3.8.3",
    "react": "^18",
    "react-dom": "^18",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.3",
    "yalc": "^1.0.0-pre.53"
  },
  "peerDependencies": {
    "@medusajs/admin-sdk": "^2.15.2",
    "@medusajs/framework": "^2.15.2",
    "@medusajs/medusa": "^2.15.2",
    "@medusajs/ui": "^4.1.12",
    "@tanstack/react-query": "5.64.2",
    "awilix": "^8.0.1",
    "react": "^18",
    "react-dom": "^18"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "yarn@4.14.1"
}
